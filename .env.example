# Supabase Configuration
# Get these values from your Supabase project settings (Settings > API)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Admin Configuration
ADMIN_PASSWORD=

# JWT secret for admin session tokens (generate with: openssl rand -hex 32)
ADMIN_JWT_SECRET=

# Supabase service role key for admin operations (Settings > API > service_role)
# WARNING: This key bypasses RLS - never expose to client
SUPABASE_SERVICE_KEY=

# Server Configuration (optional, defaults to 3001)
# PORT=3001
